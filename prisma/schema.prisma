datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl"]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  players   Player[]
  peladas   Pelada[]
  championships Championship[]
}

model Player {
  id             String   @id @default(cuid())
  name           String
  stars          Float    @default(0.0)
  active         Boolean  @default(true)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  peladaJogadores PeladaJogador[]
}

model Pelada {
  id               String   @id @default(cuid())
  title            String
  date             DateTime
  location         String?
  playersPerTeam   Int      @default(5)
  status           String   @default("agendada") // agendada, em_andamento, finalizada
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  valorTotal       Float?   @default(0.0)
  configPagamentoVisivel Boolean @default(false)
  timesJogando     Int      @default(2)
  placarCasa       Int      @default(0)
  placarVisitante  Int      @default(0)
  cronometroSegundos Int    @default(0)
  cronometroAtivo  Boolean  @default(false)
  inscritos        PeladaJogador[]
  times            TimePelada[]
}

model PeladaJogador {
  id                 String   @id @default(cuid())
  peladaId           String
  pelada             Pelada   @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  playerId           String
  player             Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  checkinOrder       Int
  presenceConfirmed  Boolean  @default(false)
  paymentConfirmed   Boolean  @default(false)
  createdAt          DateTime @default(now())
}

model TimePelada {
  id           String   @id @default(cuid())
  name         String
  color        String   @default("blue")
  order        Int
  somaEstrelas Float    @default(0.0)
  peladaId     String
  pelada       Pelada   @relation(fields: [peladaId], references: [id], onDelete: Cascade)
  jogadores    TimeJogador[]
}

model TimeJogador {
  id           String     @id @default(cuid())
  timeId       String
  time         TimePelada @relation(fields: [timeId], references: [id], onDelete: Cascade)
  playerId     String
  playerName   String?
  playerStars  Float?
  createdAt    DateTime   @default(now())
}

model Championship {
  id          String   @id @default(cuid())
  name        String
  format      String   @default("liga") // liga, mata-mata
  status      String   @default("inscricoes") // inscricoes, em_andamento, finalizado
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  teams       ChampionshipTeam[]
  games       ChampionshipGame[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChampionshipTeam {
  id              String   @id @default(cuid())
  name            String
  championshipId  String
  championship    Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  gamesHome       ChampionshipGame[] @relation("HomeTeam")
  gamesAway       ChampionshipGame[] @relation("AwayTeam")
  createdAt       DateTime @default(now())
}

model ChampionshipGame {
  id              String   @id @default(cuid())
  championshipId  String
  championship    Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  homeTeamId      String
  homeTeam        ChampionshipTeam @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeamId      String
  awayTeam        ChampionshipTeam @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  homeScore       Int      @default(0)
  awayScore       Int      @default(0)
  round           Int      @default(1)
  status          String   @default("agendado") // agendado, jogando, finalizado
  createdAt       DateTime @default(now())
}

model PlayerStats {
  id              String   @id
  playerId        String   @default("")
  goals           Int      @default(0)
  assists         Int      @default(0)
  yellowCards     Int      @default(0)
  redCards        Int      @default(0)
  matchesPlayed   Int      @default(0)
  wins            Int      @default(0)
  draws           Int      @default(0)
  losses          Int      @default(0)
  updatedAt       DateTime @updatedAt
}
